# BACKEND ENVIRONMENT VARIABLES
# Copy file ini ke .env dan isi nilainya

# Database (gunakan connection string dari Supabase/Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Secret (generate dengan: openssl rand -hex 32)
JWT_SECRET="ganti_dengan_string_acak_yang_kuat"

# Port (Render akan override otomatis via PORT env)
PORT=3001

# Backend URL (untuk file URL)
BACKEND_URL="https://api.stisipsu.ac.id"

# Node Environment
NODE_ENV=production

# Supabase (untuk file storage saat deploy ke Vercel — opsional untuk VPS)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="ganti_dengan_service_role_key_supabase"
SUPABASE_BUCKET="uploads"